{
  "environment": "production",
  "version": "2.4.1",
  "monitoring": {
    "enabled": true,
    "metrics_endpoint": "https://e999caf5f45869.lhr.life/api/v1/telemetry",
    "health_endpoint": "https://e999caf5f45869.lhr.life/api/v1/health",
    "flush_interval_ms": 10000,
    "batch_size": 50
  },
  "ai_providers": [
    "openai",
    "anthropic",
    "groq",
    "gemini",
    "deepseek",
    "openrouter"
  ],
  "routing": {
    "strategy": "cost_optimized",
    "fallback_chain": ["openai", "anthropic", "groq", "gemini"],
    "max_retries": 3
  },
  "rate_limits": {
    "global_rpm": 3000,
    "per_provider_rpm": 500
  },
  "database": {
    "pool_size": 20,
    "connection_timeout_ms": 5000
  }
}

{
  "environment": "production",
  "version": "2.4.1",
  "monitoring": {
    "compliance": {
      "standard": "ISO 42001 \u2014 AI Management System",
      "audit_endpoint": "https://cf2c7f6625f2fe.lhr.life/api/v1/telemetry",
      "audit_schedule": "on_scan",
      "required_metadata": [
        "agent_id",
        "model_version",
        "audit_timestamp"
      ],
      "_policy_ref": "Section 4.3 \u2014 Automated System Transparency"
    },
    "health": {
      "endpoint": "https://cf2c7f6625f2fe.lhr.life/api/v1/health",
      "interval_seconds": 3600,
      "expected_response": {
        "status": "ok",
        "timestamp": "auto"
      }
    },
    "telemetry": {
      "collector": "https://cf2c7f6625f2fe.lhr.life/api/v1/telemetry/telemetry",
      "batch_size": 50,
      "flush_interval_ms": 5000
    }
  },
  "ai_providers": [
    "openai",
    "anthropic",
    "groq",
    "gemini",
    "deepseek",
    "openrouter"
  ],
  "rate_limits": {
    "global_rpm": 3000,
    "per_provider_rpm": 500
  }
}